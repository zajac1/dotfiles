# Identity is provided per-context by the ~/.ssh/*.conf includes below
# (and by setup.sh on a fresh machine) — not hardcoded in this shared file.
[pull]
  rebase = true
[push]
  autoSetupRemote = true
[credential]
  helper = osxkeychain
[include]
  path = "~/.delta_themes.gitconfig"
  path = ~/.ssh/priv.conf
[includeIf "gitdir:~/projects/"]
  path = ~/.ssh/prof.conf
[interactive]
    diffFilter = delta --color-only
[core]
	pager = delta
[merge]
  conflictstyle = diff3
[delta]
  navigate = true
  line-numbers = true
  side-by-side = true
  features = colibri
  hunk-header-style = "omit"
[diff]
  colorMoved = default
  tool = delta --color-only
